---
import Logo from "./Logo.astro";
import Icon from "./Icon.astro";

interface Props {
  /** 是否显示右侧"退出"按钮(测评页用) */
  showExit?: boolean;
  /** 是否吸顶 */
  sticky?: boolean;
}

const { showExit = false, sticky = true } = Astro.props;
---

<nav
  class={sticky ? "sticky top-0 z-40 backdrop-blur-md" : ""}
  style={`background: rgba(250, 250, 247, 0.85); border-bottom: 1px solid var(--color-border-light);`}
>
  <div class="max-w-5xl mx-auto px-6 h-16 flex items-center justify-between">
    <Logo size="sm" />

    {showExit && (
      <a
        href="/"
        class="inline-flex items-center gap-1.5 text-sm transition hover:opacity-70"
        style="color: var(--color-text-muted);"
        aria-label="退出测评"
      >
        <span>退出</span>
        <Icon name="x" size={16} />
      </a>
    )}
  </div>
</nav>
