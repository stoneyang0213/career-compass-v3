[
  { "id": "h1",  "text": "我喜欢动手修理或组装机械、电器",             "chapter": 2, "order": 1, "framework": "holland", "meta": { "type": "R" } },
  { "id": "h2",  "text": "我享受户外、体力或工艺类的工作",             "chapter": 2, "order": 2, "framework": "holland", "meta": { "type": "R" } },
  { "id": "h3",  "text": "我对科学原理与现象的解释很感兴趣",           "chapter": 2, "order": 3, "framework": "holland", "meta": { "type": "I" } },
  { "id": "h4",  "text": "我喜欢通过分析数据和实验来寻找答案",         "chapter": 2, "order": 4, "framework": "holland", "meta": { "type": "I" } },
  { "id": "h5",  "text": "我享受写作、绘画、音乐或设计等创作",         "chapter": 2, "order": 5, "framework": "holland", "meta": { "type": "A" } },
  { "id": "h6",  "text": "我对审美、风格和原创表达有内在追求",         "chapter": 2, "order": 6, "framework": "holland", "meta": { "type": "A" } },
  { "id": "h7",  "text": "我喜欢帮助他人解决困扰或学习成长",           "chapter": 3, "order": 1, "framework": "holland", "meta": { "type": "S" } },
  { "id": "h8",  "text": "我擅长在团队中倾听、调和和共情",             "chapter": 3, "order": 2, "framework": "holland", "meta": { "type": "S" } },
  { "id": "h9",  "text": "我喜欢说服他人、争取支持、推动事情发生",     "chapter": 3, "order": 3, "framework": "holland", "meta": { "type": "E" } },
  { "id": "h10", "text": "我享受领导团队、销售或谈判类活动",           "chapter": 3, "order": 4, "framework": "holland", "meta": { "type": "E" } },
  { "id": "h11", "text": "我喜欢按规范流程整理资料、归档、记账",       "chapter": 3, "order": 5, "framework": "holland", "meta": { "type": "C" } },
  { "id": "h12", "text": "我享受让事物井井有条、可追溯的工作",         "chapter": 3, "order": 6, "framework": "holland", "meta": { "type": "C" } }
]
