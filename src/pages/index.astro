---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Logo from "../components/Logo.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
---

<BaseLayout>
  <Nav />

  <main>
    {/* === Hero === */}
    <section class="px-6 pt-16 pb-20 md:pt-24 md:pb-28">
      <div class="max-w-3xl mx-auto text-center">
        <Logo size="lg" withText={false} asLink={false} />

        <h1
          class="text-4xl md:text-5xl font-bold mt-8 mb-4 leading-tight"
          style="color: var(--color-text-primary); font-family: var(--font-display);"
        >
          你的 AI 时代职业罗盘
        </h1>

        <p
          class="text-xl mb-8"
          style="color: var(--color-text-secondary);"
        >
          15 分钟测评 · 7000+ 字深度报告
        </p>

        <Button href="/assess/chapter/1" size="lg">
          开始测评
          <Icon name="arrow-right" size={20} />
        </Button>

        <p class="text-sm mt-6" style="color: var(--color-text-muted);">
          不需要登录 · 不存数据 · 全程免费
        </p>
      </div>
    </section>

    {/* === 3 Step 卡(16personalities 风) === */}
    <section class="px-6 pb-24">
      <div class="max-w-5xl mx-auto">
        <h2
          class="text-center text-sm font-semibold uppercase tracking-widest mb-12"
          style="color: var(--color-text-muted); letter-spacing: 0.15em;"
        >
          整个流程分 3 步
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          {/* Step 1 */}
          <div
            class="relative rounded-2xl px-7 pt-16 pb-7 transition-all duration-200 hover:-translate-y-1"
            style="background: linear-gradient(180deg, #E8F0F7 0%, var(--color-surface) 100%); box-shadow: var(--shadow-sm); border-top: 3px solid var(--color-brand);"
          >
            <span
              class="absolute top-5 left-7 px-4 py-1 rounded-full text-xs font-bold tracking-wider"
              style="background: var(--color-brand); color: white; letter-spacing: 0.1em;"
            >
              STEP 1
            </span>
            <div
              class="absolute top-4 right-6 flex items-center justify-center rounded-2xl"
              style="width: 56px; height: 56px; background: rgba(45, 95, 139, 0.08);"
            >
              <Icon name="check" size={28} class="text-brand" stroke={2.4} />
            </div>
            <h3
              class="text-xl font-bold mb-3"
              style="color: var(--color-text-primary); font-family: var(--font-display);"
            >
              完成测评
            </h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              5 章 39 道选择题 + 3 道自由文本,15 分钟左右。Holland 兴趣 / MBTI 性格 / Super 价值观三套量表全覆盖。
            </p>
          </div>

          {/* Step 2 */}
          <div
            class="relative rounded-2xl px-7 pt-16 pb-7 transition-all duration-200 hover:-translate-y-1"
            style="background: linear-gradient(180deg, #FDEEE9 0%, var(--color-surface) 100%); box-shadow: var(--shadow-sm); border-top: 3px solid var(--color-accent);"
          >
            <span
              class="absolute top-5 left-7 px-4 py-1 rounded-full text-xs font-bold tracking-wider"
              style="background: var(--color-accent); color: white; letter-spacing: 0.1em;"
            >
              STEP 2
            </span>
            <div
              class="absolute top-4 right-6 flex items-center justify-center rounded-2xl"
              style="width: 56px; height: 56px; background: rgba(201, 122, 74, 0.10);"
            >
              <Icon name="sparkles" size={28} class="text-accent" stroke={2.4} />
            </div>
            <h3
              class="text-xl font-bold mb-3"
              style="color: var(--color-text-primary); font-family: var(--font-display);"
            >
              生成深度报告
            </h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              4-5 分钟,AI 基于你的真实测评 + 公开权威报告数据,生成行业背景 / 个人画像 / 行动建议三版块的可信报告。
            </p>
          </div>

          {/* Step 3 */}
          <div
            class="relative rounded-2xl px-7 pt-16 pb-7 transition-all duration-200 hover:-translate-y-1"
            style="background: linear-gradient(180deg, #E8F5EE 0%, var(--color-surface) 100%); box-shadow: var(--shadow-sm); border-top: 3px solid var(--color-success);"
          >
            <span
              class="absolute top-5 left-7 px-4 py-1 rounded-full text-xs font-bold tracking-wider"
              style="background: var(--color-success); color: white; letter-spacing: 0.1em;"
            >
              STEP 3
            </span>
            <div
              class="absolute top-4 right-6 flex items-center justify-center rounded-2xl"
              style="width: 56px; height: 56px; background: rgba(45, 125, 95, 0.10);"
            >
              <Icon name="target" size={28} stroke={2.4} />
            </div>
            <h3
              class="text-xl font-bold mb-3"
              style="color: var(--color-text-primary); font-family: var(--font-display);"
            >
              拿走具体行动
            </h3>
            <p class="text-sm leading-relaxed" style="color: var(--color-text-secondary);">
              每条推荐路径都附本周/本月就能做的 3 个试水动作。复制全文或打印为 PDF 留存。
            </p>
          </div>
        </div>
      </div>
    </section>

    {/* === 工具信息 === */}
    <section class="px-6 pb-20">
      <div
        class="max-w-3xl mx-auto rounded-xl p-6 text-sm leading-relaxed"
        style="background: var(--color-surface-warm); color: var(--color-text-secondary);"
      >
        <p class="mb-2">
          <strong style="color: var(--color-text-primary);">测评工具</strong>:Holland 霍兰德兴趣量表 · MBTI 性格类型 · Super 舒伯职业价值观
        </p>
        <p class="mb-2">
          <strong style="color: var(--color-text-primary);">报告模型</strong>:GLM-5.1(主)/ Kimi-K2.6(备),Cloudflare Pages 全球 Edge 部署
        </p>
        <p>
          <strong style="color: var(--color-text-primary);">报告字数</strong>:7000+ 中文字,基于真实样本 bench 验证(parseOk 100%)
        </p>
      </div>
    </section>
  </main>

  <footer
    class="px-6 py-8 text-center text-sm"
    style="color: var(--color-text-muted); border-top: 1px solid var(--color-border-light);"
  >
    <p>Career Compass v3 · MVP · 2026</p>
    <p class="mt-1">
      <a
        href="https://github.com/stoneyang0213/career-compass-v3"
        target="_blank"
        rel="noopener"
        class="hover:opacity-70 transition"
        style="color: var(--color-brand-muted);"
      >
        开源代码
      </a>
    </p>
  </footer>
</BaseLayout>
