---
import BaseLayout from "../layouts/BaseLayout.astro";
import Nav from "../components/Nav.astro";
import Logo from "../components/Logo.astro";
import Button from "../components/Button.astro";
import Icon from "../components/Icon.astro";
import ValueCard from "../components/ValueCard.astro";
---

<BaseLayout>
  <Nav />

  <main>
    {/* === Hero === */}
    <section class="px-6 pt-16 pb-20 md:pt-24 md:pb-28">
      <div class="max-w-3xl mx-auto text-center">
        <Logo size="lg" withText={false} asLink={false} />

        <h1
          class="text-4xl md:text-5xl font-bold mt-8 mb-4 leading-tight"
          style="color: var(--color-text-primary); font-family: var(--font-display);"
        >
          你的 AI 时代职业罗盘
        </h1>

        <p
          class="text-xl mb-8"
          style="color: var(--color-text-secondary);"
        >
          15 分钟测评 · 7000+ 字深度报告
        </p>

        <Button href="/assess/chapter/1" size="lg">
          开始测评
          <Icon name="arrow-right" size={20} />
        </Button>

        <p class="text-sm mt-6" style="color: var(--color-text-muted);">
          不需要登录 · 不存数据 · 全程免费
        </p>
      </div>
    </section>

    {/* === 三张价值卡 === */}
    <section class="px-6 pb-20">
      <div class="max-w-4xl mx-auto">
        <h2
          class="text-center text-sm font-semibold uppercase tracking-wider mb-8"
          style="color: var(--color-text-muted);"
        >
          这份报告会回答的 3 个问题
        </h2>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
          <ValueCard
            iconName="compass"
            title="我适合干什么?"
            description="基于 Holland 兴趣 + MBTI 性格 + Super 价值观三套量表,给你 3 条具体职业路径推荐。"
          />
          <ValueCard
            iconName="sparkles"
            title="AI 时代怎么不被替代?"
            description="结合 35 个行业的 AI 暴露度数据,告诉你哪些方向是 AI 时代的护城河。"
            accent="var(--color-accent)"
          />
          <ValueCard
            iconName="target"
            title="下一步该做什么?"
            description="每条推荐路径都附具体的下一步动作 —— 学什么、做什么项目、找谁聊。"
          />
        </div>
      </div>
    </section>

    {/* === 工具信息 === */}
    <section class="px-6 pb-20">
      <div
        class="max-w-3xl mx-auto rounded-xl p-6 text-sm leading-relaxed"
        style="background: var(--color-surface-warm); color: var(--color-text-secondary);"
      >
        <p class="mb-2">
          <strong style="color: var(--color-text-primary);">测评工具</strong>:Holland 霍兰德兴趣量表 · MBTI 性格类型 · Super 舒伯职业价值观
        </p>
        <p class="mb-2">
          <strong style="color: var(--color-text-primary);">报告模型</strong>:GLM-5.1(主)/ Kimi-K2.6(备),Cloudflare Pages 全球 Edge 部署
        </p>
        <p>
          <strong style="color: var(--color-text-primary);">报告字数</strong>:7000+ 中文字,基于真实样本 bench 验证(parseOk 100%)
        </p>
      </div>
    </section>
  </main>

  <footer
    class="px-6 py-8 text-center text-sm"
    style="color: var(--color-text-muted); border-top: 1px solid var(--color-border-light);"
  >
    <p>Career Compass v3 · MVP · 2026</p>
    <p class="mt-1">
      <a
        href="https://github.com/stoneyang0213/career-compass-v3"
        target="_blank"
        rel="noopener"
        class="hover:opacity-70 transition"
        style="color: var(--color-brand-muted);"
      >
        开源代码
      </a>
    </p>
  </footer>
</BaseLayout>
